{
  "name": "unanet-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Unanet GovCon ERP integration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "unanet-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "setup:mac": "bash setup-mac.sh",
    "prepublishOnly": "npm run build",
    "test": "npm run build && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:server": "node test-server.js",
    "mock-server": "tsx src/mock-server.ts",
    "test:integration": "sh -c 'trap \"kill 0\" EXIT; PORT=3000 npm run mock-server & sleep 2 && UNANET_USERNAME=test-user UNANET_PASSWORD=test-pass UNANET_BASE_URL=http://127.0.0.1:3000 UNANET_ALLOW_INSECURE_LOCAL_MOCK=true npm run dev' ",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "unanet",
    "govcon",
    "erp"
  ],
  "author": "GSD at Work LLC <christian@gsdat.work>",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.17.0",
    "dotenv": "^16.3.1",
    "zod": "^3.22.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^8.50.0",
    "express": "^4.22.2",
    "tsx": "^4.22.4",
    "typescript": "^5.3.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
