# Unanet Platform REST Configuration
# Use the origin only; do not include /platform/rest or embedded credentials.
UNANET_BASE_URL=https://navapbc.unanet.biz
UNANET_USERNAME=your-username
UNANET_PASSWORD=your-password

# Optional: value sent in the X-Una-App header.
UNANET_APP_NAME=NavaUnanetMCP

# Optional: expose additional read tools/resources. Name is historical;
# these tools now use Platform REST bearer-token auth.
UNANET_ENABLE_LEGACY_READ_TOOLS=false

# Optional: expose mutating tools. Keep disabled unless you explicitly want
# write-capable tools available in Claude Desktop.
UNANET_ENABLE_WRITE_TOOLS=false

# Optional: comma-separated allow-list for additional production Unanet origins.
# UNANET_ALLOWED_BASE_URLS=https://example.unanet.biz

# Optional: local mock testing only. Never enable for production URLs.
UNANET_ALLOW_INSECURE_LOCAL_MOCK=false

# Optional: logging level.
LOG_LEVEL=info
